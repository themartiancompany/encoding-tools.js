async function
  _blocks_find(
    _pattern) {
  let
    _dir,
    _msg;
  _msg =
    "Looking for files " +
    `respecting pattern '^${_pattern}*.`;
  _msg_info(
    _msg);
  _dir =
    _dirname(
      _pattern);
  console.log(_dir);
  _dir_content =
    _ls(
      _dir);
}

async function
  _buffer_prepare(
    _in,
    _out,
    _buffer_size_bytes) {
  let
    _in_size_bytes,
    _size_max,
    _split_opts,
    _msg;
  _size_max =
    0;
  if ( ! _file_exists(
           _in) ) {
    _msg =
      `File '${_in}' does ` +
      'not exist.';
    _msg_error(
      _msg,
      1);
  }
  // console.log(
  //   _in);
  _in_size_bytes =
    _stat(
      _in).size;
  _msg =
    `File '${_in}' has size ` +
    `'${_in_size_bytes}' bytes.`;
  _msg_info(
    _msg);
  console.log(
    typeof(
      _in_size_bytes));
  _blocks_total =
    Math.ceil(
      _in_size_bytes /
      _buffer_size_bytes);
  console.log(_in_size_bytes);
  console.log(_buffer_size_bytes);
  console.log(_blocks_total);
  _split_opts = [
    _in,
    `${_out}.block.`,
    _blocks_total,
    _size_max
  ];
  _split.apply(
    null,
    _split_opts);
  _blocks_find(
    `${_out}.block`);
  // console.log(
  //   _stat(
  //     _in).size / 1000);
  // console.log(
  //   _out);
}

